---
import { AdminLayout } from '@/layouts';
import { LoadingSpinner } from '@/components/ui';
---

<AdminLayout title="Website Admin Console1 | 4M">
  <section class="container-custom py-10">
    <div class="mb-6 flex items-center justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold">Website Admin Console1</h1>
        <p class="mt-1 text-sm text-muted-foreground">Manage News and Awards from one place.</p>
      </div>
      <div class="flex gap-2">
        <button id="logout-btn" class="rounded-md border px-3 py-2 text-sm">Logout</button>
      </div>
    </div>

    <div id="tab-bar" class="mb-6 rounded-lg border bg-card p-2">
      <div class="flex flex-wrap gap-2">
        <button
          id="tab-news"
          data-tab="news"
          class="rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          type="button"
        >
          News
        </button>
        <button
          id="tab-awards"
          data-tab="awards"
          class="rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          type="button"
        >
          Awards
        </button>
      </div>
    </div>

    <div id="list-view" class="rounded-lg border bg-card p-5">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h2 id="list-title" class="text-xl font-semibold">News List</h2>
        <button id="add-new-btn" class="rounded-md border px-3 py-1.5 text-sm" type="button">Add New</button>
      </div>

      <div class="mb-3 flex items-center gap-2">
        <input
          id="search-input"
          type="text"
          placeholder="Search..."
          class="w-full max-w-xs rounded-md border px-3 py-2 text-sm"
        />
        <button id="search-btn" class="rounded-md border px-3 py-2 text-sm" type="button">Search</button>
        <button id="clear-search-btn" class="rounded-md border px-3 py-2 text-sm" type="button">Clear</button>
      </div>

      <p id="list-message" class="mb-3 text-sm"></p>

      <div id="table-wrap" class="overflow-x-auto">
        <div class="grid grid-cols-[3fr_1fr_1fr_1fr_1fr] gap-4 border-b text-sm font-medium">
          <div class="py-2">
            <button type="button" class="sort-header flex items-center gap-1" data-sort="title">
              Title <span class="sort-indicator text-xs text-muted-foreground"></span>
            </button>
          </div>
          <div class="py-2">
            <button type="button" class="sort-header flex items-center gap-1" data-sort="createdAt">
              Creation <span class="sort-indicator text-xs text-muted-foreground"></span>
            </button>
          </div>
          <div class="py-2">
            <button type="button" class="sort-header flex items-center gap-1" data-sort="updatedAt">
              Modify <span class="sort-indicator text-xs text-muted-foreground"></span>
            </button>
          </div>
          <div class="py-2">
            <button type="button" class="sort-header flex items-center gap-1" data-sort="category">
              Category <span class="sort-indicator text-xs text-muted-foreground"></span>
            </button>
          </div>
          <div class="py-2 text-right">Actions</div>
        </div>
        <div id="item-grid-body"></div>
      </div>

      <p id="empty-list" class="hidden rounded-md border border-dashed p-3 text-sm text-muted-foreground">
        No items yet.
      </p>

      <div id="pagination-controls" class="mt-4 flex items-center justify-between gap-3">
        <button id="prev-page-btn" class="rounded-md border px-3 py-1.5 text-sm" type="button">Previous</button>
        <span id="page-info" class="text-sm text-muted-foreground">Page 1 of 1 (10 per page)</span>
        <button id="next-page-btn" class="rounded-md border px-3 py-1.5 text-sm" type="button">Next</button>
      </div>
    </div>

    <div id="detail-view" class="hidden rounded-lg border bg-card p-5">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h2 id="detail-title" class="text-xl font-semibold">Detail</h2>
        <button id="back-to-list-btn" class="rounded-md border px-3 py-1.5 text-sm" type="button">Back to List</button>
      </div>
      <p id="detail-message" class="mb-3 text-sm"></p>

      <form id="news-form" class="hidden space-y-3">
        <input id="news-current-id" type="hidden" />
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Title</span>
          <input id="news-title" required class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Date</span>
          <input id="news-date" required class="w-full rounded-md border px-3 py-2" placeholder="YYYY-MM-DD" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Category</span>
          <input id="news-category" required class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Excerpt</span>
          <textarea id="news-excerpt" required rows="2" class="w-full rounded-md border px-3 py-2"></textarea>
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Content (supports # ## ### and **bold**)</span>
          <textarea id="news-content" required rows="8" class="w-full rounded-md border px-3 py-2"></textarea>
        </label>
        <label class="inline-flex items-center gap-2 text-sm">
          <input id="news-featured" type="checkbox" />
          Featured
        </label>

        <div class="rounded-md border p-3">
          <p class="mb-2 text-sm font-medium">Current Image Preview</p>
          <div id="news-image-preview-wrap" class="hidden overflow-hidden rounded-md border bg-muted">
            <img id="news-image-preview" alt="News preview" class="h-44 w-full object-cover" />
          </div>
          <p id="news-image-preview-empty" class="text-xs text-muted-foreground">No image uploaded yet.</p>
        </div>

          <div class="rounded-md border p-3">
            <label class="mb-2 block text-sm font-medium" for="news-image-file">Feature image</label>
            <p class="mb-2 text-xs text-muted-foreground">Choose a file — it uploads automatically.</p>
            <input id="news-image-file" type="file" accept="image/*" class="w-full max-w-xs text-sm" />
            <p id="news-upload-status" class="mt-2 text-xs text-muted-foreground"></p>
          </div>

        <div class="flex flex-wrap gap-2 pt-1">
          <button type="submit" class="rounded-md bg-primary px-4 py-2 text-primary-foreground">Save News</button>
          <button type="button" id="news-delete-btn" class="rounded-md border px-4 py-2">Delete</button>
        </div>
      </form>

      <form id="award-form" class="hidden space-y-3">
        <input id="award-current-id" type="hidden" />
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Name</span>
          <input id="award-name" required class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Program</span>
          <input id="award-program" class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Institution</span>
          <input id="award-institution" required class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="block">
          <span class="mb-1 block text-sm font-medium">Year</span>
          <input id="award-year" class="w-full rounded-md border px-3 py-2" />
        </label>
        <label class="inline-flex items-center gap-2 text-sm">
          <input id="award-featured" type="checkbox" />
          Featured
        </label>

        <div class="rounded-md border p-3">
          <p class="mb-2 text-sm font-medium">Current Image Preview</p>
          <div id="award-image-preview-wrap" class="hidden overflow-hidden rounded-md border bg-muted">
            <img id="award-image-preview" alt="Award preview" class="h-44 w-full object-cover" />
          </div>
          <p id="award-image-preview-empty" class="text-xs text-muted-foreground">No image uploaded yet.</p>
        </div>

        <div class="rounded-md border p-3">
          <label class="mb-2 block text-sm font-medium" for="award-image-file">Award image</label>
          <p class="mb-2 text-xs text-muted-foreground">Save the award once, then choose a file — it uploads automatically.</p>
          <input id="award-image-file" type="file" accept="image/*" class="w-full max-w-xs text-sm" />
          <p id="award-upload-status" class="mt-2 text-xs text-muted-foreground"></p>
        </div>

        <div class="flex flex-wrap gap-2 pt-1">
          <button type="submit" class="rounded-md bg-primary px-4 py-2 text-primary-foreground">Save Award</button>
          <button type="button" id="award-delete-btn" class="rounded-md border px-4 py-2">Delete</button>
        </div>
      </form>
    </div>
  </section>

  <dialog id="confirm-delete-dialog" class="w-full max-w-sm rounded-lg border bg-card p-0 shadow-lg backdrop:bg-black/30">
    <form method="dialog" class="space-y-4 p-5">
      <h3 class="text-lg font-semibold">Confirm Delete</h3>
      <p id="confirm-delete-message" class="text-sm text-muted-foreground">Are you sure you want to delete this item?</p>
      <div class="flex justify-end gap-2 pt-2">
        <button value="cancel" class="rounded-md border px-3 py-1.5 text-sm" type="submit">Cancel</button>
        <button value="confirm" class="rounded-md bg-destructive px-3 py-1.5 text-sm text-destructive-foreground" type="submit">
          Delete
        </button>
      </div>
    </form>
  </dialog>

  <script>
    // @ts-nocheck
    import { adminApiFetch, clearAuthTokens, requireAdminSession } from '@/services/admin-api';

    const TAB_NEWS = 'news';
    const TAB_AWARDS = 'awards';
    const VIEW_LIST = 'list';
    const VIEW_DETAIL = 'detail';

    const state = {
      activeTab: TAB_NEWS,
      view: VIEW_LIST,
      newsPage: 1,
      awardsPage: 1,
      newsTotalPages: 1,
      awardsTotalPages: 1,
      newsSearch: '',
      awardsSearch: '',
      newsSortField: 'createdAt',
      newsSortOrder: 'desc',
      awardsSortField: 'createdAt',
      awardsSortOrder: 'desc',
      newsDraftId: '',
      newsStagedMediaId: '',
      newsUploading: false,
      awardUploading: false,
      cache: {
        news: [],
        awards: [],
      },
    };

    const el = {
      listView: document.getElementById('list-view'),
      detailView: document.getElementById('detail-view'),
      listTitle: document.getElementById('list-title'),
      listMessage: document.getElementById('list-message'),
      detailTitle: document.getElementById('detail-title'),
      detailMessage: document.getElementById('detail-message'),
      itemGridBody: document.getElementById('item-grid-body'),
      emptyList: document.getElementById('empty-list'),
      addNewBtn: document.getElementById('add-new-btn'),
      backToListBtn: document.getElementById('back-to-list-btn'),
      logoutBtn: document.getElementById('logout-btn'),
      tabBar: document.getElementById('tab-bar'),
      tabNews: document.getElementById('tab-news'),
      tabAwards: document.getElementById('tab-awards'),
      prevPageBtn: document.getElementById('prev-page-btn'),
      nextPageBtn: document.getElementById('next-page-btn'),
      pageInfo: document.getElementById('page-info'),
      searchInput: document.getElementById('search-input'),
      searchBtn: document.getElementById('search-btn'),
      clearSearchBtn: document.getElementById('clear-search-btn'),

      newsForm: document.getElementById('news-form'),
      newsCurrentId: document.getElementById('news-current-id'),
      newsTitle: document.getElementById('news-title'),
      newsDate: document.getElementById('news-date'),
      newsCategory: document.getElementById('news-category'),
      newsExcerpt: document.getElementById('news-excerpt'),
      newsContent: document.getElementById('news-content'),
      newsFeatured: document.getElementById('news-featured'),
      newsImagePreviewWrap: document.getElementById('news-image-preview-wrap'),
      newsImagePreview: document.getElementById('news-image-preview'),
      newsImagePreviewEmpty: document.getElementById('news-image-preview-empty'),
      newsImageFile: document.getElementById('news-image-file'),
      newsUploadStatus: document.getElementById('news-upload-status'),
      newsDeleteBtn: document.getElementById('news-delete-btn'),

      awardForm: document.getElementById('award-form'),
      awardCurrentId: document.getElementById('award-current-id'),
      awardName: document.getElementById('award-name'),
      awardProgram: document.getElementById('award-program'),
      awardInstitution: document.getElementById('award-institution'),
      awardYear: document.getElementById('award-year'),
      awardFeatured: document.getElementById('award-featured'),
      awardImagePreviewWrap: document.getElementById('award-image-preview-wrap'),
      awardImagePreview: document.getElementById('award-image-preview'),
      awardImagePreviewEmpty: document.getElementById('award-image-preview-empty'),
      awardImageFile: document.getElementById('award-image-file'),
      awardUploadStatus: document.getElementById('award-upload-status'),
      awardDeleteBtn: document.getElementById('award-delete-btn'),
      confirmDeleteDialog: document.getElementById('confirm-delete-dialog'),
      confirmDeleteMessage: document.getElementById('confirm-delete-message'),
    };

    function normalizeTab(raw) {
      return raw === TAB_AWARDS ? TAB_AWARDS : TAB_NEWS;
    }

    function currentNewsId() {
      return el.newsCurrentId.value.trim();
    }

    function currentAwardId() {
      return el.awardCurrentId.value.trim();
    }

    function toExtension(filename) {
      const idx = filename.lastIndexOf('.');
      return idx >= 0 ? filename.slice(idx + 1).toLowerCase() : 'jpg';
    }

    function formatDate(value) {
      if (!value) return '-';
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return String(value);
      const y = String(d.getFullYear());
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const day = String(d.getDate()).padStart(2, '0');
      return `${y}-${m}-${day}`;
    }

    function getItemsFromPayload(data) {
      const items = Array.isArray(data?.items) ? data.items : [];
      return items;
    }

    function setListMessage(message, isError = false) {
      el.listMessage.textContent = message;
      el.listMessage.className = `mb-3 text-sm ${isError ? 'text-red-600' : 'text-green-600'}`;
    }

    function setDetailMessage(message, isError = false) {
      el.detailMessage.textContent = message;
      el.detailMessage.className = `mb-3 text-sm ${isError ? 'text-red-600' : 'text-green-600'}`;
    }

    function setSubmitDisabled(formEl, disabled) {
      const btn = formEl?.querySelector('button[type="submit"]');
      if (btn instanceof HTMLButtonElement) {
        btn.disabled = Boolean(disabled);
      }
    }

    function beginNewsUpload() {
      state.newsUploading = true;
      setSubmitDisabled(el.newsForm, true);
      el.newsImageFile.disabled = true;
    }

    function endNewsUpload() {
      state.newsUploading = false;
      setSubmitDisabled(el.newsForm, false);
      el.newsImageFile.disabled = false;
    }

    function beginAwardUpload() {
      state.awardUploading = true;
      setSubmitDisabled(el.awardForm, true);
      el.awardImageFile.disabled = true;
    }

    function endAwardUpload() {
      state.awardUploading = false;
      setSubmitDisabled(el.awardForm, false);
      el.awardImageFile.disabled = false;
    }

    function normalizeMediaUrl(candidate) {
      if (typeof candidate !== 'string') return '';
      let trimmed = candidate.trim();
      if (!trimmed) return '';
      if (trimmed.startsWith('/api/v1/')) {
        trimmed = `/api/backend${trimmed.slice('/api/v1'.length)}`;
      }
      return trimmed;
    }

    function pickImageUrlFromDetail(detail) {
      const medias = Array.isArray(detail?.medias) ? detail.medias : [];
      const fromMedia = medias
        .map((m) => normalizeMediaUrl(
          m?.thumbnailSignedUrl ?? m?.thumbnail_signed_url ?? m?.signedUrl ?? m?.signed_url ?? m?.proxyUrl ?? m?.proxy_url ?? m?.publicUrl ?? m?.public_url,
        ))
        .find(Boolean);

      return fromMedia
        || normalizeMediaUrl(detail?.image)
        || normalizeMediaUrl(detail?.media_destination)
        || '';
    }

    function setPreview(url, imageEl, wrapEl, emptyEl) {
      if (!url) {
        imageEl.removeAttribute('src');
        wrapEl.classList.add('hidden');
        emptyEl.classList.remove('hidden');
        return;
      }
      imageEl.src = url;
      wrapEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
    }

    function setNewsPreview(url) {
      setPreview(url, el.newsImagePreview, el.newsImagePreviewWrap, el.newsImagePreviewEmpty);
    }

    function setAwardPreview(url) {
      setPreview(url, el.awardImagePreview, el.awardImagePreviewWrap, el.awardImagePreviewEmpty);
    }

    function confirmDeleteAction(message) {
      const dialog = el.confirmDeleteDialog;
      if (!(dialog instanceof HTMLDialogElement) || typeof dialog.showModal !== 'function') {
        return Promise.resolve(window.confirm(message));
      }
      el.confirmDeleteMessage.textContent = message;
      dialog.returnValue = '';
      dialog.showModal();
      return new Promise((resolve) => {
        const onClose = () => {
          dialog.removeEventListener('close', onClose);
          resolve(dialog.returnValue === 'confirm');
        };
        dialog.addEventListener('close', onClose);
      });
    }

    function resetNewsForm() {
      el.newsCurrentId.value = '';
      el.newsTitle.value = '';
      el.newsDate.value = '';
      el.newsCategory.value = '';
      el.newsExcerpt.value = '';
      el.newsContent.value = '';
      el.newsFeatured.checked = false;
      el.newsUploadStatus.textContent = '';
      el.newsImageFile.value = '';
      setNewsPreview('');
      state.newsDraftId = '';
      state.newsStagedMediaId = '';
    }

    function resetAwardForm() {
      el.awardCurrentId.value = '';
      el.awardName.value = '';
      el.awardProgram.value = '';
      el.awardInstitution.value = '';
      el.awardYear.value = '';
      el.awardFeatured.checked = false;
      el.awardUploadStatus.textContent = '';
      el.awardImageFile.value = '';
      setAwardPreview('');
    }

    function updateUrlParams() {
      const current = new URL(window.location.href);
      current.searchParams.set('tab', state.activeTab);
      window.history.replaceState({}, '', `${current.pathname}?${current.searchParams.toString()}`);
    }

    function renderTabs() {
      const tabs = [
        { node: el.tabNews, tab: TAB_NEWS },
        { node: el.tabAwards, tab: TAB_AWARDS },
      ];
      tabs.forEach(({ node, tab }) => {
        const active = state.activeTab === tab;
        node.className = active
          ? 'rounded-md border bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-colors'
          : 'rounded-md border px-4 py-2 text-sm font-medium transition-colors hover:bg-secondary';
      });
    }

    function renderSortIndicators() {
      const isNews = state.activeTab === TAB_NEWS;
      const sortField = isNews ? state.newsSortField : state.awardsSortField;
      const sortOrder = isNews ? state.newsSortOrder : state.awardsSortOrder;

      document.querySelectorAll('.sort-header').forEach((btn) => {
        const indicator = btn.querySelector('.sort-indicator');
        const field = btn.getAttribute('data-sort');
        if (!indicator) return;

        if (field === sortField) {
          indicator.textContent = sortOrder === 'asc' ? '▲' : '▼';
          indicator.classList.remove('text-muted-foreground');
          indicator.classList.add('text-primary');
        } else {
          indicator.textContent = '';
          indicator.classList.add('text-muted-foreground');
          indicator.classList.remove('text-primary');
        }
      });
    }

    function showListView() {
      state.view = VIEW_LIST;
      el.listView.classList.remove('hidden');
      el.detailView.classList.add('hidden');
      el.tabBar.classList.remove('hidden');
      setDetailMessage('');
    }

    function showDetailView() {
      state.view = VIEW_DETAIL;
      el.listView.classList.add('hidden');
      el.detailView.classList.remove('hidden');
      el.tabBar.classList.add('hidden');
      el.newsForm.classList.toggle('hidden', state.activeTab !== TAB_NEWS);
      el.awardForm.classList.toggle('hidden', state.activeTab !== TAB_AWARDS);
    }

    function showTableLoading() {
      el.itemGridBody.innerHTML = '';
      const row = document.createElement('div');
      row.className = 'grid grid-cols-[3fr_1fr_1fr_1fr_1fr] gap-4 py-8';
      const cell = document.createElement('div');
      cell.className = 'col-span-5 text-center';
      const spinner = document.createElement('span');
      spinner.className = 'inline-block h-8 w-8 animate-spin rounded-full border-2 border-current border-t-transparent text-primary';
      spinner.setAttribute('role', 'status');
      spinner.setAttribute('aria-label', 'loading');
      cell.appendChild(spinner);
      row.appendChild(cell);
      el.itemGridBody.appendChild(row);
    }

    function renderList() {
      const isNews = state.activeTab === TAB_NEWS;
      const items = isNews ? state.cache.news : state.cache.awards;
      el.listTitle.textContent = isNews ? 'News List' : 'Awards List';
      el.addNewBtn.textContent = isNews ? 'Add New News' : 'Add New Award';

      el.searchInput.value = isNews ? state.newsSearch : state.awardsSearch;
      renderSortIndicators();

      el.itemGridBody.innerHTML = '';
      if (items.length === 0) {
        el.emptyList.classList.remove('hidden');
        return;
      }
      el.emptyList.classList.add('hidden');

      items.forEach((item) => {
        const row = document.createElement('div');
        row.className = 'grid grid-cols-[3fr_1fr_1fr_1fr_1fr] gap-4 border-b py-3 hover:bg-muted/50';

        const titleCell = document.createElement('div');
        titleCell.className = 'flex items-center';
        const titleBtn = document.createElement('button');
        titleBtn.type = 'button';
        titleBtn.className = 'text-left font-medium hover:underline';
        titleBtn.dataset.action = 'view';
        titleBtn.dataset.id = String(item.id);
        titleBtn.textContent = isNews ? (item.title || '(untitled news)') : (item.name || '(untitled award)');
        titleCell.appendChild(titleBtn);

        const createdCell = document.createElement('div');
        createdCell.className = 'flex items-center whitespace-nowrap';
        createdCell.textContent = formatDate(item.createdAt ?? item.created_at);

        const updatedCell = document.createElement('div');
        updatedCell.className = 'flex items-center whitespace-nowrap';
        updatedCell.textContent = formatDate(item.updatedAt ?? item.updated_at);

        const categoryCell = document.createElement('div');
        categoryCell.className = 'flex items-center';
        categoryCell.textContent = isNews
          ? (item.category || '-')
          : (item.program || item.institution || item.year || '-');

        const actionsCell = document.createElement('div');
        actionsCell.className = 'flex items-center justify-end';
        const actionsWrap = document.createElement('div');
        actionsWrap.className = 'flex gap-2';

        const editBtn = document.createElement('button');
        editBtn.type = 'button';
        editBtn.className = 'rounded-md border px-3 py-1.5 text-xs';
        editBtn.textContent = 'Edit';
        editBtn.dataset.action = 'edit';
        editBtn.dataset.id = String(item.id);

        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'rounded-md border px-3 py-1.5 text-xs';
        deleteBtn.textContent = 'Delete';
        deleteBtn.dataset.action = 'delete';
        deleteBtn.dataset.id = String(item.id);

        actionsWrap.appendChild(editBtn);
        actionsWrap.appendChild(deleteBtn);
        actionsCell.appendChild(actionsWrap);

        row.appendChild(titleCell);
        row.appendChild(createdCell);
        row.appendChild(updatedCell);
        row.appendChild(categoryCell);
        row.appendChild(actionsCell);
        el.itemGridBody.appendChild(row);
      });
    }

    function renderPagination() {
      const isNews = state.activeTab === TAB_NEWS;
      const page = isNews ? state.newsPage : state.awardsPage;
      const totalPages = isNews ? state.newsTotalPages : state.awardsTotalPages;

      el.pageInfo.textContent = `Page ${page} of ${totalPages} (10 per page)`;
      el.prevPageBtn.disabled = page <= 1;
      el.nextPageBtn.disabled = page >= totalPages;

      el.prevPageBtn.classList.toggle('opacity-50', page <= 1);
      el.nextPageBtn.classList.toggle('opacity-50', page >= totalPages);
    }

    async function loadActiveList() {
      const isNews = state.activeTab === TAB_NEWS;
      const page = isNews ? state.newsPage : state.awardsPage;
      const search = isNews ? state.newsSearch : state.awardsSearch;
      const sort = isNews ? state.newsSortField : state.awardsSortField;
      const order = isNews ? state.newsSortOrder : state.awardsSortOrder;

      const params = new URLSearchParams();
      params.set('page', String(page));
      params.set('limit', '10');
      if (search) params.set('search', search);
      if (sort) params.set('sort', sort);
      if (order) params.set('order', order);

      const path = isNews ? `/news?${params.toString()}` : `/awards?${params.toString()}`;

      el.emptyList.classList.add('hidden');
      showTableLoading();

      try {
        const data = await adminApiFetch(path);
        const items = getItemsFromPayload(data);
        if (isNews) {
          state.cache.news = items;
          state.newsTotalPages = data?.pagination?.totalPages || 1;
        } else {
          state.cache.awards = items;
          state.awardsTotalPages = data?.pagination?.totalPages || 1;
        }
        renderList();
        renderPagination();
      } catch (error) {
        el.itemGridBody.innerHTML = '';
        setListMessage(error instanceof Error ? error.message : 'Failed to load list', true);
      }
    }

    async function loadNewsDetail(newsId) {
      const detail = await adminApiFetch(`/news/${encodeURIComponent(newsId)}`);
      el.newsCurrentId.value = detail.id || '';
      el.newsTitle.value = detail.title || '';
      el.newsDate.value = detail.date || '';
      el.newsCategory.value = detail.category || '';
      el.newsExcerpt.value = detail.excerpt || '';
      el.newsContent.value = detail.content || '';
      el.newsFeatured.checked = Boolean(detail.featured);
      el.newsUploadStatus.textContent = '';
      setNewsPreview(pickImageUrlFromDetail(detail));
      state.newsDraftId = '';
      state.newsStagedMediaId = '';
    }

    async function loadAwardDetail(awardId) {
      const detail = await adminApiFetch(`/awards/${encodeURIComponent(awardId)}`);
      el.awardCurrentId.value = String(detail.id || '');
      el.awardName.value = detail.name || '';
      el.awardProgram.value = detail.program || '';
      el.awardInstitution.value = detail.institution || '';
      el.awardYear.value = detail.year || '';
      el.awardFeatured.checked = Boolean(detail.featured);
      el.awardUploadStatus.textContent = '';
      setAwardPreview(pickImageUrlFromDetail(detail));
    }

    async function openCreate() {
      setDetailMessage('');
      if (state.activeTab === TAB_NEWS) {
        resetNewsForm();
        el.detailTitle.textContent = 'Add New News';
      } else {
        resetAwardForm();
        el.detailTitle.textContent = 'Add New Award';
      }
      showDetailView();
    }

    async function openDetail(itemId) {
      setDetailMessage('');
      if (state.activeTab === TAB_NEWS) {
        await loadNewsDetail(itemId);
        el.detailTitle.textContent = 'News Detail';
      } else {
        await loadAwardDetail(itemId);
        el.detailTitle.textContent = 'Award Detail';
      }
      showDetailView();
    }

    async function deleteById(itemId) {
      const itemLabel = state.activeTab === TAB_NEWS ? 'news item' : 'award';
      const confirmed = await confirmDeleteAction(`Delete this ${itemLabel}?`);
      if (!confirmed) {
        return false;
      }

      if (state.activeTab === TAB_NEWS) {
        await adminApiFetch(`/news/${encodeURIComponent(itemId)}`, { method: 'DELETE' });
        setListMessage('News deleted.');
      } else {
        await adminApiFetch(`/awards/${encodeURIComponent(itemId)}`, { method: 'DELETE' });
        setListMessage('Award deleted.');
      }
      await loadActiveList();
      showListView();
      return true;
    }

    async function uploadNewsImage() {
      const file = el.newsImageFile.files?.[0];
      if (!file) {
        return;
      }

      const existingNewsId = currentNewsId();
      const isDraft = !existingNewsId;
      if (isDraft && !state.newsDraftId) {
        state.newsDraftId = crypto.randomUUID();
      }
      const ownerId = isDraft ? state.newsDraftId : existingNewsId;
      const contentType = file.type || 'application/octet-stream';
      const extension = toExtension(file.name);

      beginNewsUpload();
      el.newsUploadStatus.textContent = 'Uploading…';
      try {
        const req = await adminApiFetch('/media/upload-request', {
          method: 'POST',
          body: JSON.stringify({
            entityType: 'news',
            entityId: ownerId,
            contentType,
            extension,
          }),
        });

        await adminApiFetch('/media/upload-bytes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/octet-stream',
            'x-cms-object-key': req.objectKey,
            'x-cms-content-type': contentType,
          },
          body: file,
        });

        const confirm = await adminApiFetch('/media/upload-confirm', {
          method: 'POST',
          body: JSON.stringify({
            objectKey: req.objectKey,
            register: {
              ownerType: isDraft ? 'news-draft' : 'news',
              ownerId,
              sortOrder: 0,
              contentType,
            },
          }),
        });
        state.newsStagedMediaId = confirm.mediaId || '';
        setNewsPreview(normalizeMediaUrl(confirm.thumbnail?.signedUrl ?? confirm.signedUrl ?? confirm.publicUrl ?? confirm.proxyUrl));
        el.newsUploadStatus.textContent = 'Upload done';
      } catch (error) {
        el.newsUploadStatus.textContent = '';
        setDetailMessage(error instanceof Error ? error.message : 'Upload failed', true);
      } finally {
        endNewsUpload();
      }
    }

    async function uploadAwardImage() {
      const id = currentAwardId();
      const file = el.awardImageFile.files?.[0];
      if (!file) {
        return;
      }
      if (!id) {
        setDetailMessage('Save this award once before adding an image.', true);
        el.awardImageFile.value = '';
        return;
      }
      const contentType = file.type || 'application/octet-stream';
      const extension = toExtension(file.name);

      beginAwardUpload();
      el.awardUploadStatus.textContent = 'Uploading…';
      try {
        const req = await adminApiFetch('/media/upload-request', {
          method: 'POST',
          body: JSON.stringify({
            entityType: 'awards',
            entityId: id,
            contentType,
            extension,
          }),
        });

        await adminApiFetch('/media/upload-bytes', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/octet-stream',
            'x-cms-object-key': req.objectKey,
            'x-cms-content-type': contentType,
          },
          body: file,
        });

        const confirm = await adminApiFetch('/media/upload-confirm', {
          method: 'POST',
          body: JSON.stringify({
            objectKey: req.objectKey,
            register: {
              ownerType: 'award',
              ownerId: id,
              sortOrder: 0,
              contentType,
            },
          }),
        });
        setAwardPreview(normalizeMediaUrl(confirm.thumbnail?.signedUrl ?? confirm.signedUrl ?? confirm.publicUrl ?? confirm.proxyUrl));
        el.awardUploadStatus.textContent = 'Upload done';
      } catch (error) {
        el.awardUploadStatus.textContent = '';
        setDetailMessage(error instanceof Error ? error.message : 'Upload failed', true);
      } finally {
        endAwardUpload();
      }
    }

    async function saveNews(event) {
      event.preventDefault();

      if (state.newsUploading) {
        setDetailMessage('Wait until the upload finishes before saving.', true);
        return;
      }

      const existingId = currentNewsId();
      const newId = state.newsDraftId || crypto.randomUUID();
      const payload = {
        title: el.newsTitle.value.trim(),
        date: el.newsDate.value.trim(),
        excerpt: el.newsExcerpt.value.trim(),
        content: el.newsContent.value,
        category: el.newsCategory.value.trim(),
        featured: Boolean(el.newsFeatured.checked),
      };

      let finalNewsId = existingId;
      if (existingId) {
        await adminApiFetch(`/news/${encodeURIComponent(existingId)}`, {
          method: 'PATCH',
          body: JSON.stringify(payload),
        });
      } else {
        const created = await adminApiFetch('/news', {
          method: 'POST',
          body: JSON.stringify({ id: newId, ...payload }),
        });
        finalNewsId = created.id;
      }

      if (state.newsDraftId) {
        await adminApiFetch('/media/draft-news/relink', {
          method: 'POST',
          body: JSON.stringify({
            draftId: state.newsDraftId,
            newsId: finalNewsId,
          }),
        });
        state.newsDraftId = '';
        state.newsStagedMediaId = '';
      }

      await loadActiveList();
      showListView();
      setListMessage('News saved successfully.');
    }

    async function saveAward(event) {
      event.preventDefault();

      if (state.awardUploading) {
        setDetailMessage('Wait until the upload finishes before saving.', true);
        return;
      }

      const payload = {
        name: el.awardName.value.trim(),
        program: el.awardProgram.value.trim(),
        institution: el.awardInstitution.value.trim(),
        year: el.awardYear.value.trim(),
        featured: Boolean(el.awardFeatured.checked),
      };

      const id = currentAwardId();
      if (id) {
        await adminApiFetch(`/awards/${encodeURIComponent(id)}`, {
          method: 'PATCH',
          body: JSON.stringify(payload),
        });
      } else {
        const created = await adminApiFetch('/awards', {
          method: 'POST',
          body: JSON.stringify(payload),
        });
        el.awardCurrentId.value = String(created.id || '');
      }

      await loadActiveList();
      showListView();
      setListMessage('Award saved successfully.');
    }

    async function deleteCurrentFromDetail() {
      const id = state.activeTab === TAB_NEWS ? currentNewsId() : currentAwardId();
      if (!id) {
        setDetailMessage('Select an existing item first.', true);
        return;
      }
      await deleteById(id);
    }

    function handleSort(field) {
      const isNews = state.activeTab === TAB_NEWS;
      const currentField = isNews ? state.newsSortField : state.awardsSortField;
      const currentOrder = isNews ? state.newsSortOrder : state.awardsSortOrder;

      let newOrder = 'asc';
      if (field === currentField) {
        newOrder = currentOrder === 'asc' ? 'desc' : 'asc';
      }

      if (isNews) {
        state.newsSortField = field;
        state.newsSortOrder = newOrder;
      } else {
        state.awardsSortField = field;
        state.awardsSortOrder = newOrder;
      }

      renderSortIndicators();
      loadActiveList().catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to sort', true));
    }

    function handleSearch() {
      const isNews = state.activeTab === TAB_NEWS;
      const value = el.searchInput.value.trim();
      if (isNews) {
        state.newsSearch = value;
        state.newsPage = 1;
      } else {
        state.awardsSearch = value;
        state.awardsPage = 1;
      }
      loadActiveList().catch((error) => setListMessage(error instanceof Error ? error.message : 'Search failed', true));
    }

    function clearSearch() {
      el.searchInput.value = '';
      const isNews = state.activeTab === TAB_NEWS;
      if (isNews) {
        state.newsSearch = '';
        state.newsPage = 1;
      } else {
        state.awardsSearch = '';
        state.awardsPage = 1;
      }
      loadActiveList().catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to clear search', true));
    }

    async function switchTab(tab) {
      state.activeTab = normalizeTab(tab);
      renderTabs();
      updateUrlParams();
      setListMessage('');
      showListView();
      await loadActiveList();
    }

    function bindEvents() {
      el.tabNews.addEventListener('click', () => {
        switchTab(TAB_NEWS).catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to load tab', true));
      });
      el.tabAwards.addEventListener('click', () => {
        switchTab(TAB_AWARDS).catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to load tab', true));
      });

      el.logoutBtn.addEventListener('click', () => {
        clearAuthTokens();
        window.location.href = `/admin/login?redirect=${encodeURIComponent('/admin/dashboard')}`;
      });

      el.addNewBtn.addEventListener('click', () => {
        openCreate().catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Failed to start create mode', true));
      });
      el.backToListBtn.addEventListener('click', () => showListView());

      el.itemGridBody.addEventListener('click', (event) => {
        const target = event.target;
        const button = target instanceof HTMLElement ? target.closest('button[data-action][data-id]') : null;
        if (!button) return;
        const id = button.getAttribute('data-id');
        const action = button.getAttribute('data-action');
        if (!id || !action) return;

        if (action === 'delete') {
          deleteById(id).catch((error) => setListMessage(error instanceof Error ? error.message : 'Delete failed', true));
          return;
        }

        openDetail(id).catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Load failed', true));
      });

      el.newsForm.addEventListener('submit', (event) => {
        saveNews(event).catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Save failed', true));
      });
      el.newsDeleteBtn.addEventListener('click', () => {
        deleteCurrentFromDetail().catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Delete failed', true));
      });
      el.newsImageFile.addEventListener('change', () => {
        uploadNewsImage().catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Upload failed', true));
      });

      el.awardForm.addEventListener('submit', (event) => {
        saveAward(event).catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Save failed', true));
      });
      el.awardDeleteBtn.addEventListener('click', () => {
        deleteCurrentFromDetail().catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Delete failed', true));
      });
      el.awardImageFile.addEventListener('change', () => {
        uploadAwardImage().catch((error) => setDetailMessage(error instanceof Error ? error.message : 'Upload failed', true));
      });

      el.prevPageBtn.addEventListener('click', () => {
        const isNews = state.activeTab === TAB_NEWS;
        const currentPage = isNews ? state.newsPage : state.awardsPage;
        if (currentPage > 1) {
          if (isNews) state.newsPage--;
          else state.awardsPage--;
          loadActiveList().catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to load page', true));
        }
      });

      el.nextPageBtn.addEventListener('click', () => {
        const isNews = state.activeTab === TAB_NEWS;
        const currentPage = isNews ? state.newsPage : state.awardsPage;
        const totalPages = isNews ? state.newsTotalPages : state.awardsTotalPages;
        if (currentPage < totalPages) {
          if (isNews) state.newsPage++;
          else state.awardsPage++;
          loadActiveList().catch((error) => setListMessage(error instanceof Error ? error.message : 'Failed to load page', true));
        }
      });

      el.searchBtn.addEventListener('click', handleSearch);
      el.clearSearchBtn.addEventListener('click', clearSearch);
      el.searchInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          handleSearch();
        }
      });

      document.querySelectorAll('.sort-header').forEach((btn) => {
        btn.addEventListener('click', () => {
          const field = btn.getAttribute('data-sort');
          if (field) handleSort(field);
        });
      });
    }

    async function bootstrap() {
      try {
        await requireAdminSession();
      } catch (_error) {
        window.location.href = `/admin/login?redirect=${encodeURIComponent(`${window.location.pathname}${window.location.search}`)}`;
        return;
      }

      state.activeTab = normalizeTab(new URLSearchParams(window.location.search).get('tab') || TAB_NEWS);
      renderTabs();
      showListView();
      bindEvents();
      await loadActiveList();
    }

    bootstrap().catch((error) => {
      setListMessage(error instanceof Error ? error.message : 'Initialization failed', true);
    });
  </script>
</AdminLayout>
