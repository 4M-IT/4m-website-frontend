---
export interface Props {
  id?: string;
  class?: string;
  size?: "sm" | "md" | "lg";
}

const { id, class: className = "", size = "md" } = Astro.props;

const sizeClasses = {
  sm: "h-4 w-4 border-2",
  md: "h-8 w-8 border-2",
  lg: "h-12 w-12 border-4",
};
---

<div
  id={id}
  class={`inline-block ${sizeClasses[size]} rounded-full border-current border-t-transparent animate-spin ${className}`}
  role="status"
  aria-label="loading"
>
  <span class="sr-only">Loading...</span>
</div>
