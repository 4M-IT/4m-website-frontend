# Copy to `.env.local` (gitignored) for full-stack local UI testing.
#
# 1) Start the backend on the same machine first: `cd ../4M-web-backend && npm run dev` (default PORT 3000).
# 2) Backend should use your Railway Postgres + Tigris credentials in `.env.development` (or equivalent).
# 3) JWT_* secrets on the API must be non-placeholder (min length per env schema) or login will fail.

PUBLIC_API_URL=/api/backend
API_INTERNAL_URL=http://127.0.0.1:3000

# Optional: helps SSR resolve relative API paths if you rely on `site` in astro.config
# SITE_URL=http://127.0.0.1:4321
