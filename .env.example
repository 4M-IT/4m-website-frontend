# Browser-facing API base (frontend proxy path).
PUBLIC_API_URL=/api/backend

# Product detail: set to false, 0, no, or off to hide the share / social block.
# PUBLIC_PRODUCT_DETAIL_SOCIAL=true

# Server-only backend origin (no trailing slash, do not include /api/v1).
# SSR and the /api/backend/* proxy resolve paths under /api/v1 on this host.
# Example for local/dev:
# API_INTERNAL_URL=http://127.0.0.1:3000
# Example for Railway private networking:
# API_INTERNAL_URL=http://4m-backend.railway.internal
API_INTERNAL_URL=https://4m-backend-production.up.railway.app
